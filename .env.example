# Copy to .env and fill in real values. docker-compose.yml reads these.
# Only needed for features that call external services.

# Cloudinary (required for image/video uploads)
SOCIAL_APP_CLOUDINARY_CLOUD_NAME=
SOCIAL_APP_CLOUDINARY_CLOUD_API_KEY=
SOCIAL_APP_CLOUDINARY_CLOUD_SECRET_KEY=

# Mail (required for verification / forgot-password emails)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
